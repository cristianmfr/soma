{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot --env-file=../../.env src/index.ts",
    "start": "bun run dist/main.mjs"
  },
  "dependencies": {
    "@elysia/cors": "^1.4.2",
    "@elysia/openapi": "^1.4.15",
    "@soma/auth": "workspace:*",
    "@soma/db": "workspace:*",
    "@soma/env": "workspace:*",
    "dotenv": "catalog:",
    "elysia": "latest",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@soma/typescript-config": "workspace:*",
    "typescript": "catalog:",
    "@types/bun": "catalog:",
    "tsdown": "^0.22.3"
  },
  "module": "src/index.js"
}