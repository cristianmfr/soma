{
  "name": "soma",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @soma/db",
    "db:reset": "turbo run db:reset -F @soma/db",
    "db:generate": "turbo run db:generate -F @soma/db",
    "db:migrate": "turbo run db:migrate -F @soma/db",
    "db:start": "docker compose up -d postgres redis",
    "db:watch": "docker compose up postgres redis",
    "db:stop": "docker compose stop postgres redis",
    "db:down": "docker compose down postgres redis",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "config/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/bun": "^1.3.14",
      "elysia": "^1.4.29",
      "better-auth": "1.6.23",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.2",
      "@prisma/adapter-pg": "^7.8.0",
      "@prisma/client": "^7.8.0",
      "prisma": "^7.8.0",
      "ky": "^2.0.2"
    }
  },
  "dependencies": {
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@soma/typescript-config": "workspace:*",
    "@biomejs/biome": "2.5.4",
    "@types/bun": "catalog:",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.4"
}